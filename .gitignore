# dependencies
node_modules/

# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# CLI build output is regenerated by `npm install` (prepare script).
# packages/cli/registry/files/ is INTENTIONALLY committed: it's the bundled
# component source the CLI copies into consumers. `prepare` keeps it in
# sync with packages/ui/src/ on every install.

