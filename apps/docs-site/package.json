    "typecheck": "astro check"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.0",
    "@astrojs/mdx": "^4.3.14",
    "@astrojs/starlight": "^0.32.0",
    "astro": "^5.0.0",
    "sharp": "^0.33.5",
    "typescript": "~5.9.2"
  }
}
