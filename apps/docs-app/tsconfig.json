{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "paths": {
      "*": ["./*"],
      "@/*": ["./src/*"],
      "@/assets/*": ["./assets/*"],
      "@stylesheet-ui/ui": ["../../packages/ui/src"],
      "@stylesheet-ui/ui/*": ["../../packages/ui/src/*"]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts"
  ]
}
