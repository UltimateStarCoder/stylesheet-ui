{
  "name": "stylesheet-ui",
  "version": "0.0.1",
  "description": "Add stylesheet-ui components to your Expo / React Native project.",
  "type": "commonjs",
  "bin": {
    "stylesheet-ui": "dist/index.js"
  },
  "files": [
    "dist",
    "registry"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs --target node18 --clean --shims --no-splitting",
    "dev": "tsup src/index.ts --format cjs --target node18 --watch --shims --no-splitting",
    "sync": "tsx scripts/sync-registry.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "fs-extra": "^11.2.0",
    "picocolors": "^1.0.1",
    "prompts": "^2.4.2"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^20.11.0",
    "@types/prompts": "^2.4.9",
    "tsup": "^8.0.0",
    "tsx": "^4.7.0",
    "typescript": "~5.9.2"
  }
}
