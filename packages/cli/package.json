{
  "name": "stylesheet-ui",
  "version": "0.0.2",
  "description": "shadcn-style copy-paste components for Expo / React Native. Plain StyleSheet, no DSL. Run `npx stylesheet-ui add <name>` to drop a component into your project.",
  "keywords": [
    "expo",
    "react-native",
    "components",
    "ui",
    "design-system",
    "stylesheet",
    "shadcn",
    "cli"
  ],
  "homepage": "https://github.com/UltimateStarCoder/stylesheet-ui#readme",
  "bugs": {
    "url": "https://github.com/UltimateStarCoder/stylesheet-ui/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/UltimateStarCoder/stylesheet-ui.git",
    "directory": "packages/cli"
  },
  "license": "MIT",
  "author": "Mac-Rufus Umeokolo",
  "type": "commonjs",
  "engines": {
    "node": ">=18"
  },
  "bin": {
    "stylesheet-ui": "dist/index.js"
  },
  "files": [
    "dist",
    "registry",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs --target node18 --clean --shims --no-splitting",
    "dev": "tsup src/index.ts --format cjs --target node18 --watch --shims --no-splitting",
    "sync": "tsx scripts/sync-registry.ts",
    "prepare": "npm run sync && npm run build",
    "prepublishOnly": "npm run sync && npm run build",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "fs-extra": "^11.2.0",
    "picocolors": "^1.0.1",
    "prompts": "^2.4.2",
    "semver": "^7.6.0"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^20.11.0",
    "@types/prompts": "^2.4.9",
    "@types/semver": "^7.5.8",
    "tsup": "^8.0.0",
    "tsx": "^4.7.0",
    "typescript": "~5.9.2"
  },
  "publishConfig": {
    "access": "public"
  }
}
